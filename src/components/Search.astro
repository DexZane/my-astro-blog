---
const normalizedBaseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<site-search>
  <div id="search" class="search-container"></div>
</site-search>

<link href={`${normalizedBaseUrl}pagefind/pagefind-ui.css`} rel="stylesheet" />
<script is:inline src={`${normalizedBaseUrl}pagefind/pagefind-ui.js`}></script>

<script>
  class SiteSearch extends HTMLElement {
    connectedCallback() {
      const target = this.querySelector('#search');
      if (!target || target.dataset.initialized) return;
      target.dataset.initialized = "true";

      const init = () => {
        if (window.PagefindUI) {
          new window.PagefindUI({ element: "#search", showSubResults: true });
        } else {
          setTimeout(init, 50);
        }
      };
      
      init();
    }
  }

  if (!customElements.get('site-search')) {
    customElements.define('site-search', SiteSearch);
  }
</script>

<style>
  .search-container {
    margin: 2rem 0;
  }
</style>
