---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Hi, I'm Dongze 👋</h1>
			<p>
				Welcome to my personal blog. I share project notes, engineering lessons, and long-term reflections here.
			</p>
			<p>
				If you're new here, start with the <a href="about/">about page</a>, or jump directly to the
				<a href="blog/">blog posts</a>.
			</p>
			<p>Topics I currently focus on:</p>
			<ul>
				<li>Astro and static-site engineering practices</li>
				<li>Debugging stories and project retrospectives</li>
				<li>Learning systems and long-term growth</li>
			</ul>
			<p>
				You can also use the <a href="search/">search page</a> to quickly find articles.
			</p>
		</main>
		<Footer />
	</body>
</html>
