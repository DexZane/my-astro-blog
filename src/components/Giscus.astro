---
interface Props {
	lang?: string;
}

const { lang = 'en' } = Astro.props;
---

<div class="giscus"></div>

<script is:inline define:vars={{ lang }}>
	const GISCUS_SRC = 'https://giscus.app/client.js';
	const GISCUS_ORIGIN = 'https://giscus.app';
	const GISCUS_PAGELOAD_HANDLER_KEY = '__giscusPageLoadHandler__';
	const GISCUS_THEME_OBSERVER_KEY = '__giscusThemeObserver__';
	const GISCUS_PATHNAME_KEY = '__giscusPathname__';
	const GISCUS_LANG_MAP = {
		'zh-cn': 'zh-CN'
	};

	function getGiscusLang(locale) {
		return GISCUS_LANG_MAP[locale] || locale;
	}

	function getGiscusTheme() {
		return document.documentElement.classList.contains('dark') ? 'transparent_dark' : 'light';
	}

	function updateGiscusTheme() {
		const theme = getGiscusTheme();
		const iframe = document.querySelector('iframe.giscus-frame');
		if (iframe && iframe.contentWindow) {
			iframe.contentWindow.postMessage({ giscus: { setConfig: { theme } } }, GISCUS_ORIGIN);
		}
	}

	function ensureThemeObserver() {
		if (window[GISCUS_THEME_OBSERVER_KEY]) {
			return;
		}

		const observer = new MutationObserver((mutations) => {
			mutations.forEach((mutation) => {
				if (mutation.attributeName === 'class') {
					updateGiscusTheme();
				}
			});
		});

		observer.observe(document.documentElement, { attributes: true });
		window[GISCUS_THEME_OBSERVER_KEY] = observer;
	}

	function loadGiscus(pathChanged) {
		const container = document.querySelector('.giscus');
		if (!container) {
			return;
		}

		if (pathChanged) {
			container.innerHTML = '';
		}

		if (!pathChanged && container.querySelector('iframe.giscus-frame')) {
			return;
		}

		if (container.querySelector(`script[src="${GISCUS_SRC}"]`)) {
			return;
		}

		const script = document.createElement('script');
		script.src = GISCUS_SRC;
		script.setAttribute('data-repo', 'mimanchi-dongze/my-astro-blog');
		script.setAttribute('data-repo-id', 'R_kgDORswhuQ');
		script.setAttribute('data-category', 'General');
		script.setAttribute('data-category-id', 'DIC_kwDORswhuc4C46hR');
		script.setAttribute('data-mapping', 'pathname');
		script.setAttribute('data-strict', '0');
		script.setAttribute('data-reactions-enabled', '1');
		script.setAttribute('data-emit-metadata', '0');
		script.setAttribute('data-input-position', 'bottom');
		script.setAttribute('data-theme', getGiscusTheme());
		script.setAttribute('data-lang', getGiscusLang(lang));
		script.setAttribute('crossorigin', 'anonymous');
		script.async = true;
		container.appendChild(script);
	}

	function initializeGiscus() {
		const pathname = window.location.pathname;
		const pathChanged = window[GISCUS_PATHNAME_KEY] !== pathname;
		window[GISCUS_PATHNAME_KEY] = pathname;

		loadGiscus(pathChanged);
		ensureThemeObserver();
		updateGiscusTheme();
	}

	if (!window[GISCUS_PAGELOAD_HANDLER_KEY]) {
		const onPageLoad = () => initializeGiscus();
		document.addEventListener('astro:page-load', onPageLoad);
		window[GISCUS_PAGELOAD_HANDLER_KEY] = onPageLoad;
	}

	initializeGiscus();
</script>
